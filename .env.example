# 环境变量示例文件
# 复制为 .env 后修改配置

# 配置文件路径
CONFIG_PATH=./config/config.yaml

# 数据库配置（覆盖配置文件）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=go_api_project

# JWT 密钥（生产环境必须修改）
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# 服务器配置
SERVER_PORT=8080
SERVER_MODE=debug

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
